{
	"quietStartup": true,
	"theme": "agentcastle",
	"sessionDir": ".pi/sessions",
	"contextStatusBar": {
		"showTps": true
	},
	"docker": {
		"memory": "4G",
		"cpus": "2.0"
	},
	"skills": [".pi/skills"],
	"prompts": [
		"prompts",
		"prompts/operations",
		"prompts/development",
		"prompts/requirement",
		"prompts/misc"
	],
	"supervisor": {
		"repo": "SchneiderDaniel/agentcastle",
		"projectNumber": 3,
		"statusField": "Status",
		"statusMapping": {
			"Research": "researcher",
			"Architecture": "architect",
			"TestDesign": "test-designer",
			"Implementation": "developer",
			"Audit": "auditor"
		},
		"maxRejections": 5,
		"codeowners": ["SchneiderDaniel"],
		"agentTimeoutsMin": {},
		"agentTokenBudget": 300000,
		"bellOnComplete": false,
		"commentSummaryThreshold": 7,
		"maxCommentChars": 2000
	}
}
