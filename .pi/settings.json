{
	"quietStartup": true,
	"theme": "agentcastle",
	"sessionDir": ".pi/sessions",
	"contextStatusBar": {
		"showTps": true
	},
	"rankedMap": {
		"tokenBudget": 2048,
		"recencyWindowDays": 30,
		"cacheTtlHours": 24,
		"autoThreshold": 20000,
		"weights": {
			"keyword": 0.5,
			"recency": 0.3
		}
	},
	"docker": {
		"memory": "4G",
		"cpus": "2.0"
	},
	"supervisor": {
		"repo": "SchneiderDaniel/agentcastle",
		"projectNumber": 3,
		"statusField": "Status",
		"statusMapping": {
			"Research": "researcher",
			"Architecture": "architect",
			"TestDesign": "test-designer",
			"Implementation": "developer",
			"Audit": "auditor"
		},
		"maxRejections": 5,
		"codeowners": ["SchneiderDaniel"],
		"agentTimeoutsMin": {},
		"bellOnComplete": false
	}
}
